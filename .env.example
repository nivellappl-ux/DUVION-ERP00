# Configurações Obrigatórias para Vercel

# 1. Supabase (URL e Chaves da API)
# Encontras estes valores no teu Dashboard do Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://teu-id-supabase.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# 2. Configurações da Empresa (Opcional se alterares o ID na BD)
# ID da empresa padrão definida no sistema (vê a tabela `empresas`)
NEXT_PUBLIC_EMPRESA_PADRAO_ID=00000000-0000-0000-0000-000000000001
